# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173

# ── AI Model ──────────────────────────────────────────────────────────────────
MODEL_NAME=claude-sonnet-4.6

# ── Session management ────────────────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=15

# Set to true to enable demo mode (approves all tool permission requests).
# WARNING: Only use in local/demo environments, never in production.
DEMO_MODE=false

# ── Buffer search limits ──────────────────────────────────────────────────────
BUFFER_DISTANCE_MIN_METERS=10
BUFFER_DISTANCE_MAX_METERS=50000
BUFFER_RESULT_LIMIT=200

# ── Azure Blob Storage (demo – document access) ───────────────────────────────
AZURE_CONNECTION_STRING=your-azure-connection-string-here
BLOB_CONTAINER_NAME=your-container-name-here

# ── PostgreSQL database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ── MCP server (db_mcp_server.py) ─────────────────────────────────────────────
MCP_PORT=8002
